# Andhra Kitchen Agent - Environment Configuration Template
# Copy this file to .env and fill in your values

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=YOUR_ACCOUNT_ID_HERE

# Environment (dev or prod)
ENVIRONMENT=dev

# DynamoDB Tables (auto-populated after deployment)
SESSIONS_TABLE=kitchen-agent-sessions-dev
MARKET_PRICES_TABLE=kitchen-agent-market-prices-dev
REMINDERS_TABLE=kitchen-agent-reminders-dev

# S3 Bucket (auto-populated after deployment)
IMAGE_BUCKET=kitchen-agent-images-YOUR_ACCOUNT_ID-dev

# API Gateway (auto-populated after deployment)
API_ENDPOINT=https://YOUR_API_ID.execute-api.ap-south-1.amazonaws.com/v1

# Bedrock Models
BEDROCK_CHAT_MODEL=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_VISION_MODEL=anthropic.claude-3-sonnet-20240229-v1:0

# Application Settings
MAX_IMAGE_SIZE_MB=10
IMAGE_EXPIRY_HOURS=24
SESSION_TTL_DAYS=7
REMINDER_TTL_DAYS=7

# Rate Limiting
API_RATE_LIMIT=100
API_BURST_LIMIT=20

# Logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=7

# Feature Flags
ENABLE_FESTIVAL_MODE=true
ENABLE_VOICE_INPUT=true
ENABLE_REMINDERS=true

# Festival Dates (YYYY-MM-DD)
SANKRANTI_DATE=2024-01-15
UGADI_DATE=2024-04-09
DASARA_DATE=2024-10-12
DEEPAVALI_DATE=2024-11-01
