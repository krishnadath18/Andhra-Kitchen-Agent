# Andhra Kitchen Agent - Environment Configuration Template
# Copy this file to .env and fill in your values

# ==================== AWS CONFIGURATION ====================

# AWS Account ID (12-digit number)
AWS_ACCOUNT_ID=123456789012

# AWS Region (Mumbai region for optimal latency to Andhra Pradesh)
AWS_REGION=ap-south-1

# ==================== AWS SERVICE ENDPOINTS ====================

# API Gateway Endpoint (get from CloudFormation outputs)
API_ENDPOINT=https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com/v1

# ==================== COGNITO CONFIGURATION ====================

# Cognito region (normally same as AWS_REGION)
COGNITO_REGION=ap-south-1

# Cognito User Pool ID and App Client ID for Streamlit login and local JWT validation
COGNITO_USER_POOL_ID=ap-south-1_example
COGNITO_APP_CLIENT_ID=exampleclientid

# ==================== DYNAMODB TABLES ====================

# DynamoDB table names (from CloudFormation outputs)
SESSIONS_TABLE=kitchen-agent-sessions-dev
MARKET_PRICES_TABLE=kitchen-agent-market-prices-dev
REMINDERS_TABLE=kitchen-agent-reminders-dev

# ==================== LAMBDA CONFIGURATION ====================

# Lambda function ARN for reminder execution (from CloudFormation outputs)
REMINDER_LAMBDA_ARN=arn:aws:lambda:ap-south-1:123456789012:function:kitchen-agent-reminder-executor-dev

# ==================== S3 CONFIGURATION ====================

# S3 bucket for image storage (from CloudFormation outputs)
IMAGE_BUCKET=kitchen-agent-images-123456789012-dev

# Image expiry time in hours (default: 24)
IMAGE_EXPIRY_HOURS=24

# ==================== BEDROCK CONFIGURATION ====================

# Bedrock region (same as AWS_REGION)
BEDROCK_REGION=ap-south-1

# Bedrock model identifiers
BEDROCK_MODEL_VISION=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MODEL_CHAT=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MODEL_RECIPE=anthropic.claude-3-haiku-20240307-v1:0

# ==================== VISION ANALYZER CONFIGURATION ====================

# Confidence thresholds for ingredient detection
VISION_CONFIDENCE_HIGH=0.7
VISION_CONFIDENCE_MEDIUM=0.5

# Retry and timeout settings
VISION_MAX_RETRIES=3
VISION_TIMEOUT_SECONDS=10

# ==================== RECIPE GENERATOR CONFIGURATION ====================

# Recipe generation limits
RECIPE_MIN_COUNT=2
RECIPE_MAX_COUNT=5
RECIPE_MAX_PREP_TIME=30

# Low-oil recipe constraint (tablespoons per serving)
RECIPE_LOW_OIL_MAX_TBSP=2.0

# ==================== SESSION CONFIGURATION ====================

# Session TTL in days
SESSION_TTL_DAYS=7

# ==================== API CONFIGURATION ====================

# Backend API Base URL (for Streamlit frontend)
API_BASE_URL=http://localhost:5000

# API request timeout in seconds
API_TIMEOUT=30

# API max retries
API_MAX_RETRIES=3

# API rate limiting
API_RATE_LIMIT=100
API_BURST_LIMIT=20
RATE_LIMITER_FAIL_CLOSED=false
RATE_LIMITER_RETRY_AFTER_SECONDS=60
INCLUDE_RATE_LIMIT_HEADERS=true
MAX_REQUEST_SIZE_BYTES=1048576
MAX_UPLOAD_REQUEST_SIZE_BYTES=14680064

# ==================== APPLICATION CONFIGURATION ====================

# Environment (dev, prod)
ENVIRONMENT=dev

# Debug mode (True, False)
DEBUG=False

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# CORS and transport security
ALLOWED_ORIGIN=http://localhost:8501
REQUIRE_HTTPS=true
HTTPS_REDIRECT_ENABLED=false

# Input validation hardening
INPUT_VALIDATION_STRICT=true
MAX_WHITESPACE_RATIO=0.5
SESSION_ID_STRICT_VALIDATION=true
SESSION_ID_RESERVED_KEYWORDS=admin,root,system,config,superuser,support,ops

# Response header hardening
CSP_STRICT_MODE=true
CSP_ALLOW_INLINE_STYLES=true
# CSP_REPORT_URI=https://your-report-endpoint.example.com/csp

# Frontend password guidance
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SPECIAL=true
SHOW_PASSWORD_STRENGTH=true

# Default language (en, te)
DEFAULT_LANGUAGE=en

# ==================== MARKET CONFIGURATION ====================

# Default market for price lookups
DEFAULT_MARKET=rythu_bazaar_vijayawada

# Days after which prices are considered outdated
PRICE_OUTDATED_DAYS=30

# ==================== FESTIVAL CONFIGURATION ====================

# Enable festival mode
FESTIVAL_MODE_ENABLED=True

# Serving size multiplier during festivals
FESTIVAL_SERVING_MULTIPLIER=1.5

# ==================== NOTES ====================
# 
# 1. Get AWS_ACCOUNT_ID from AWS Console or run: aws sts get-caller-identity --query Account --output text
# 2. Get API_ENDPOINT from CloudFormation stack outputs after deployment
# 3. Get table names and bucket name from CloudFormation stack outputs
# 4. Ensure Bedrock models are enabled in your AWS account (Console → Bedrock → Model access)
# 5. Never commit .env file to version control (it's in .gitignore)
#
